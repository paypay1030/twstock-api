# ═══════════════════════════════════════════
# 我的持股管家 API — 環境變數設定
# ═══════════════════════════════════════════
# 複製此檔為 .env，填入實際值

# 環境（development / production）
# 生產環境務必設為 production，否則資料失敗時會顯示模擬數據
APP_ENV=production

# 允許的前端網域（CORS），多個用逗號分隔
# 本機開發：http://localhost:3000
# 正式部署：https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── 技術參數（可保留預設值）──────────────────
VOLUME_PROFILE_BUCKETS=60
SIGNAL_RESIST_NEAR=0.03
SIGNAL_RESIST_MID=0.06
SIGNAL_SUPPORT_NEAR=0.03

# 快取時間（秒）
CACHE_TTL_PRICE=300
CACHE_TTL_HISTORY=3600
